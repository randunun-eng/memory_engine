# memory_engine environment configuration
# Copy to .env.local and fill in. .env.local is gitignored.
#
# Format: KEY=value, no quotes, no spaces around =.

# --- Required for production (not tests) -----------------------------

# Vault master key (32 bytes, base64-encoded).
# Generate: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
MEMORY_ENGINE_VAULT_KEY=

# Path to TOML config. Defaults to config/default.toml.
MEMORY_ENGINE_CONFIG=config/default.toml

# --- Required for Phase 5 (WhatsApp adapter) ------------------------

# Per-persona WhatsApp credentials are stored in mcp_sources; no
# environment config needed beyond what 'memory-engine mcp register'
# captures.

# --- Optional: override config.toml via environment ------------------

# Log level: DEBUG, INFO, WARNING, ERROR
# MEMORY_ENGINE_LOG_LEVEL=INFO

# DB path or URL
# MEMORY_ENGINE_DB__BACKEND=sqlite
# MEMORY_ENGINE_DB__PATH=data/engine.db
# MEMORY_ENGINE_DB__URL=postgresql+asyncpg://user:pass@host:5432/db

# Policy plane LLM endpoint
# MEMORY_ENGINE_POLICY__LLM_BASE_URL=http://localhost:11434/v1
# MEMORY_ENGINE_POLICY__DEFAULT_MODEL=llama3.2:3b

# Grounding threshold
# MEMORY_ENGINE_GROUNDING__SIMILARITY_THRESHOLD=0.40

# Monthly LLM budget (0 = local-only mode)
# MEMORY_ENGINE_MONTHLY_BUDGET_USD=12.00

# --- Optional: Phase 6 backup ---------------------------------------

# age public key for backup encryption. Private key stored separately.
# MEMORY_ENGINE_BACKUP_RECIPIENT=age1...

# Offsite backup destination
# MEMORY_ENGINE_BACKUP_DEST=s3://my-bucket/memory_engine_backups/

# --- LLM provider credentials (if using paid endpoints) -------------

# Anthropic (if using claude-* models via policy plane)
# ANTHROPIC_API_KEY=

# OpenAI (if using gpt-* models)
# OPENAI_API_KEY=

# LiteLLM proxy (recommended for multi-provider routing)
# LITELLM_API_KEY=
