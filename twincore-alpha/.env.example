# ============================================================
# TwinCore Alpha configuration
# Copy to .env and fill in. NEVER commit .env.
# ============================================================

# --- Persona ---
PERSONA_SLUG=randunu_primary
PERSONA_ID=1

# --- LLM (Gemini 2.5 Flash via Google AI Studio) ---
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza_YOUR_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# --- memory_engine ---
MEMORY_ENGINE_URL=http://memory-engine:4000
MEMORY_ENGINE_VAULT_KEY=GENERATED_AT_BOOTSTRAP
MEMORY_ENGINE_MCP_PRIVATE_KEY=GENERATED_AT_BOOTSTRAP
PERSONA_OWNER_PRIVATE_KEY=GENERATED_AT_BOOTSTRAP
PERSONA_OWNER_PUBLIC_KEY=GENERATED_AT_BOOTSTRAP

# --- whatsapp-bridge ---
WHATSAPP_BRIDGE_URL=http://whatsapp-bridge:8080
WHATSAPP_BRIDGE_DB_PATH=/app/whatsapp-bridge/store/messages.db

# --- twin-agent runtime ---
TWIN_POLL_INTERVAL_SEC=3
AUTO_REPLY_ENABLED=false
SYNC_FROM_ISO=2026-04-17T00:00:00Z
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=500

# --- control-plane ---
CONTROL_PLANE_PORT=4500
CONTROL_PLANE_DB_PATH=/app/control-plane-data/control.db

# --- UTF-8 ---
PYTHONIOENCODING=utf-8
LANG=en_US.UTF-8
LC_ALL=en_US.UTF-8
