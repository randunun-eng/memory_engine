<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>ai.twincore.ocr-watcher</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Users/YOUR_USER/Memory_engine/twincore-alpha/bin/ocr-watcher.sh</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/Users/YOUR_USER/Library/Logs/twincore/ocr-watcher.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/YOUR_USER/Library/Logs/twincore/ocr-watcher.err</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
  </dict>
</dict>
</plist>

<!--
Install:
  cp ai.twincore.ocr-watcher.plist.example ~/Library/LaunchAgents/ai.twincore.ocr-watcher.plist
  # replace YOUR_USER with `whoami`
  launchctl load ~/Library/LaunchAgents/ai.twincore.ocr-watcher.plist
-->
